{
    "version": 2,
    "builds": [
        {
            "src": "**/*.html",
            "use": "@vercel/static"
        },
        {
            "src": "**/*.css",
            "use": "@vercel/static"
        },
        {
            "src": "**/*.js",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/",
            "dest": "/index.html"
        },
        {
            "src": "/customers",
            "dest": "/customers.html"
        },
        {
            "src": "/automations",
            "dest": "/automations.html"
        },
        {
            "src": "/login",
            "dest": "/login.html"
        },
        {
            "src": "/forgot-password",
            "dest": "/forgot-password.html"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ],
    "cleanUrls": true,
    "trailingSlash": false
}
